{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Flask app",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python app.py",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Build Docker image",
      "type": "shell",
      "command": "docker build -t musiccamp-form .",
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
