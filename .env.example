# Copy this file to .env and fill in the values.
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
# Optional: change the target range where rows will be appended.
GOOGLE_SHEETS_RANGE=FormResponses!A2
# Optional webhook URL instead of direct Sheets API writes.
# GOOGLE_SHEETS_WEBHOOK_URL=https://example.com/your-apps-script-endpoint
